#!/bin/bash
# ─── Personal Ollama / SSH config (TEMPLATE) ──────────────────────────────────
# Copy this file to `ollama.local.sh` and fill in your own values:
#
#     cp ollama.local.sh.example ollama.local.sh
#
# `ollama.local.sh` is git-ignored, so your host/usernames never get committed.
# start.sh sources it automatically (if present) before launching the server.
#
# Two ways to use the frontend "LLM Generation" feature:
#
#   A) Local Ollama (simplest): run `ollama serve` on this machine, leave the
#      SSH_* / TUNNEL_PORT vars below blank, and set
#          export OLLAMA_HOST="http://localhost:11434"
#      No tunnel is opened.
#
#   B) Remote Ollama over an SSH tunnel (what the original author uses): set the
#      SSH_* vars and TUNNEL_PORT below. start.sh then opens
#          ssh -N -f -J "$SSH_JUMP" -L ${TUNNEL_PORT}:localhost:11434 "$SSH_TARGET" -p "$SSH_PORT"
#      forwarding your local TUNNEL_PORT to the remote host's `ollama serve`
#      (which listens on 11434). A non-default local port (e.g. 11500) avoids
#      colliding with any Ollama already running locally on 11434.
#
# The tunnel opens only when BOTH SSH_TARGET and TUNNEL_PORT are set.
#
# NOTE: the tunnel is now opened *lazily by the backend* — only when you enter
# the "LLM Generation" panel in the UI — not at server startup. start.sh just
# exports these vars for the backend to rebuild the ssh command. If this file is
# absent entirely, the LLM panel shows setup instructions instead of connecting.

# --- Remote SSH host (option B). Leave blank for a local Ollama (option A). ---
SSH_JUMP=""              # optional jump/bastion, e.g. "user@bastion.example.edu"
SSH_TARGET=""            # remote Ollama host, e.g. "user@gpu-box.example.edu"
SSH_PORT=22              # SSH port of SSH_TARGET
TUNNEL_PORT=""           # local port to forward, e.g. 11500 (blank = no tunnel)

# --- Where the generator looks for Ollama. ---
# Option A: http://localhost:11434   Option B: http://localhost:${TUNNEL_PORT}
export OLLAMA_HOST="http://localhost:11434"

# Model served by Ollama (optional; claude_generate.py defaults to qwen2.5:7b).
# export OLLAMA_MODEL="qwen2.5:7b"

# --- GPU status (optional). ---
# Lets /api/llm_status run `nvidia-smi` on the remote host over SSH when this
# server runs somewhere without a GPU. Leave blank to run nvidia-smi locally
# (or skip it). For option B, mirror your SSH args, e.g.:
#   export GPU_SSH="-J $SSH_JUMP -p $SSH_PORT $SSH_TARGET"
export GPU_SSH=""

# --- GPU selection. ---
# The LLM panel's GPU column is informational only. Where Ollama runs as a
# shared, root-owned system service it auto-schedules GPUs and can't be pinned
# per request, so the panel just highlights the GPU it's most likely to use (the
# most-free card). GPU_SSH above is all that's needed (for the nvidia-smi readout).

# --- CoTSimilarity sample evaluation (optional). ---
# The authoring app can score pulled/verified samples with the CoTSimilarity /
# DSPR model running on the SAME remote host (see cot_eval_service/README.md).
# The backend forwards this port over the SAME SSH tunnel it opens for Ollama, so
# no extra SSH config is needed — just run the shim on the remote:
#
#   cd <CoTSimilarity repo root>   # e.g. /scratch/<user>/DSPR
#   pip install -r cot_eval_service/requirements-shim.txt
#   export DEEPSEEK_API_KEY=...    # ON THE REMOTE — enables the GED score only
#   uvicorn cot_eval_service.app:app --host 127.0.0.1 --port 8100 --workers 1
#
#   COT_EVAL_PORT  remote shim port AND local forward port (default 8100).
#   COT_EVAL_N     samples per variant for the solvability pass-rate (default 10).
#                  Timing tests found n=10 (30 vLLM generations per pair-eval:
#                  10 each for original/simple/hard) averaged 88-113s/problem
#                  regardless of GED model — n is the dominant cost, not GED.
#                  Lower to 5 if you need to stay near ~1min/problem.
#   COT_EVAL_HOST  override the URL the app POSTs to (default http://localhost:$COT_EVAL_PORT).
export COT_EVAL_PORT="8100"
export COT_EVAL_N="5"
# export COT_EVAL_HOST="http://localhost:8100"

# After editing cot_eval_service/app.py locally, redeploy with one command:
#   ./scripts/deploy_eval_shim.sh
# It scp's cot_eval_service/ to REMOTE_DSPR_DIR and restarts uvicorn there via
# cot_eval_service/restart.sh (which sources ~/.cot_eval_env on the remote for
# GED secrets — create that file once by hand, see restart.sh's header).
REMOTE_DSPR_DIR=""   # e.g. "/scratch/<user>/DSPR" (the CoTSimilarity repo root)
